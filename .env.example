# =========================================================================
#                    ResumeIQ Environment Configuration Template
# =========================================================================
# Rename this file to '.env' for local backend usage, or upload to your
# server deployment dashboard (Render, Railway, AWS).
# Keep all secret keys on the server-side backend ONLY!
# =========================================================================

# -------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (Server-Side Backend Only)
# -------------------------------------------------------------------------
# Local PostgreSQL Connection string. Ensure it uses standard psycopg2 driver.
DATABASE_URL=postgresql://postgres:password@localhost:5432/ats_optimizer

# -------------------------------------------------------------------------
# 2. JWT & AUTH SECURITY (Server-Side Backend Only)
# -------------------------------------------------------------------------
# SECRET_KEY must be a cryptographically secure random string (minimum 32 chars).
# Example command to generate one: openssl rand -hex 32
SECRET_KEY=your-cryptographically-secure-secret-key-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -------------------------------------------------------------------------
# 3. AI ENDPOINT KEYS (Server-Side Backend Only - NEVER expose to Frontend!)
# -------------------------------------------------------------------------
# Groq Llama 3/3.1 API Key
GROQ_API_KEY=gsk-your-secure-groq-api-key-goes-here

# -------------------------------------------------------------------------
# 4. FILE STORAGE CONFIGURATION (Server-Side Backend Only)
# -------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# -------------------------------------------------------------------------
# 5. CORS / HOSTS SETUP (Server-Side Backend Only)
# -------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -------------------------------------------------------------------------
# 6. SUPABASE AUTHENTICATION OAUTH INTEGRATION (Server-Side & Client Shared)
# -------------------------------------------------------------------------
# Backend private/public parameters:
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-public-key

# =========================================================================
#                    NEXT.JS FRONTEND CONFIGURATION
# =========================================================================
# Place the following inside your 'frontend/.env.local' file.
# NEVER place secret backend keys (like GROQ_API_KEY or DATABASE_URL) here!
# Prefix variables with 'NEXT_PUBLIC_' to expose them to Next.js client bundles.
# =========================================================================

# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anonymous-public-key
